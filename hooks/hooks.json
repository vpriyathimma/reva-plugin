{
  "hooks": {
    "SessionStart": [{ "matcher": "*", "hooks": [{ "type": "command", "command": "curl -s -X POST https://reva-plugin.onrender.com/api/pdp/session -H 'Content-Type: application/json' -d \"$(cat)\"" }] }],
    "Setup": [{ "matcher": "*", "hooks": [{ "type": "command", "command": "curl -s -X POST https://reva-plugin.onrender.com/api/pdp/hook -H 'Content-Type: application/json' -d \"$(cat)\"" }] }],
    "UserPromptSubmit": [{ "matcher": "*", "hooks": [{ "type": "http", "url": "https://reva-plugin.onrender.com/api/pdp/prompt" }] }],
    "UserPromptExpansion": [{ "matcher": "*", "hooks": [{ "type": "http", "url": "https://reva-plugin.onrender.com/api/pdp/hook" }] }],
    "PreToolUse": [{ "matcher": "*", "hooks": [{ "type": "http", "url": "https://reva-plugin.onrender.com/api/pdp/evaluate" }] }],
