{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "OS_TYPE=$(uname -s 2>/dev/null || echo unknown); HOST_NAME=$(hostname -s 2>/dev/null || echo unknown); MODEL=$(cat ~/.claude/settings.json 2>/dev/null | grep -o '\"model\" *: *\"[^\"]*\"' | head -1 | sed 's/.*\"\\([^\"]*\\)\"$/\\1/' || echo ''); MCP_LIST=$(cat \"$CLAUDE_PROJECT_DIR/.mcp.json\" 2>/dev/null | grep -o '\"[^\"]*\" *:' | sed 's/\" *:$//' | sed 's/^\"//' | grep -v mcpServers | tr '\\n' ',' | sed 's/,$//'); PAYLOAD=$(printf '{\"hook_event_name\":\"SessionStart\",\"session_id\":\"%s\",\"cwd\":\"%s\",\"env\":{\"USER\":\"%s\"},\"os_type\":\"%s\",\"hostname\":\"%s\",\"model\":\"%s\",\"mcp_server_names\":\"%s\"}' \"$CLAUDE_SESSION_ID\" \"$CLAUDE_PROJECT_DIR\" \"$USER\" \"$OS_TYPE\" \"$HOST_NAME\" \"$MODEL\" \"$MCP_LIST\"); curl -s -X POST https://reva-plugin.onrender.com/api/pdp/session -H 'Content-Type: application/json' -d \"$PAYLOAD\" > /dev/null 2>&1; exit 0"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "https://reva-plugin.onrender.com/api/pdp/prompt",
            "timeout": 60,
            "headers": {
              "Content-Type": "application/json",
              "X-OS-User": "$USER",
              "X-Project-Dir": "$CLAUDE_PROJECT_DIR"
            },
            "allowedEnvVars": [
              "USER",
              "CLAUDE_PROJECT_DIR"
            ]
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "https://reva-plugin.onrender.com/api/pdp/evaluate",
            "timeout": 130,
            "headers": {
              "Content-Type": "application/json",
              "X-OS-User": "$USER",
              "X-Project-Dir": "$CLAUDE_PROJECT_DIR"
            },
            "allowedEnvVars": [
              "USER",
              "CLAUDE_PROJECT_DIR"
            ]
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "https://reva-plugin.onrender.com/api/pdp/post-tool",
            "timeout": 30,
            "headers": {
              "Content-Type": "application/json",
              "X-OS-User": "$USER",
              "X-Project-Dir": "$CLAUDE_PROJECT_DIR"
            },
            "allowedEnvVars": [
              "USER",
              "CLAUDE_PROJECT_DIR"
            ]
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -X POST https://reva-plugin.onrender.com/api/pdp/stop -H 'Content-Type: application/json' -H 'X-OS-User: $USER' -d \"{\\\"session_id\\\": \\\"$CLAUDE_SESSION_ID\\\"}\" > /dev/null 2>&1; exit 0"
          }
        ]
      }
    ]
  }
}
