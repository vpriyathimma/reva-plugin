    "TaskCreated": [{ "matcher": "*", "hooks": [{ "type": "http", "url": "https://reva-plugin.onrender.com/api/pdp/hook" }] }],
    "TaskCompleted": [{ "matcher": "*", "hooks": [{ "type": "http", "url": "https://reva-plugin.onrender.com/api/pdp/hook" }] }],
