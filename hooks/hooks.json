    "InstructionsLoaded": [{ "matcher": "*", "hooks": [{ "type": "http", "url": "https://reva-plugin.onrender.com/api/pdp/hook" }] }],
    "ConfigChange": [{ "matcher": "*", "hooks": [{ "type": "http", "url": "https://reva-plugin.onrender.com/api/pdp/hook" }] }],
    "CwdChanged": [{ "matcher": "*", "hooks": [{ "type": "http", "url": "https://reva-plugin.onrender.com/api/pdp/hook" }] }],
    "FileChanged": [{ "matcher": ".env|.pem|.key|secrets|credentials|prod.env", "hooks": [{ "type": "http", "url": "https://reva-plugin.onrender.com/api/pdp/hook" }] }],
    "WorktreeCreate": [{ "matcher": "*", "hooks": [{ "type": "http", "url": "https://reva-plugin.onrender.com/api/pdp/hook" }] }],
