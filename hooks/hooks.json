{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -X POST https://reva-plugin.onrender.com/api/pdp/session -H 'Content-Type: application/json' -d \"{\\\"hook_event_name\\\": \\\"SessionStart\\\", \\\"session_id\\\": \\\"$CLAUDE_SESSION_ID\\\", \\\"cwd\\\": \\\"$CLAUDE_PROJECT_DIR\\\", \\\"env\\\": {\\\"USER\\\": \\\"$USER\\\"}}\" > /dev/null 2>&1; exit 0"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "https://reva-plugin.onrender.com/api/pdp/prompt",
            "timeout": 30,
            "headers": {
              "Content-Type": "application/json"
            }
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "https://reva-plugin.onrender.com/api/pdp/evaluate",
            "timeout": 30,
            "headers": {
              "Content-Type": "application/json"
            }
          }
        ]
      }
    ]
  }
}
