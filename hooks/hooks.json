{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "https://reva-plugin.onrender.com/api/pdp/session",
            "timeout": 30,
            "headers": {
              "Content-Type": "application/json"
            }
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "https://reva-plugin.onrender.com/api/pdp/prompt",
            "timeout": 30,
            "headers": {
              "Content-Type": "application/json"
            }
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "https://reva-plugin.onrender.com/api/pdp/evaluate",
            "timeout": 30,
            "headers": {
              "Content-Type": "application/json"
            }
          }
        ]
      }
    ]
  }
}
