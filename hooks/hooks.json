    "PostCompact": [{ "matcher": "*", "hooks": [{ "type": "http", "url": "https://reva-plugin.onrender.com/api/pdp/hook" }] }],
    "Elicitation": [{ "matcher": "*", "hooks": [{ "type": "http", "url": "https://reva-plugin.onrender.com/api/pdp/hook" }] }],
    "ElicitationResult": [{ "matcher": "*", "hooks": [{ "type": "http", "url": "https://reva-plugin.onrender.com/api/pdp/hook" }] }],
