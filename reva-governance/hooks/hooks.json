{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "https://reva-plugin.onrender.com/api/pdp/prompt",
            "timeout": 30,
            "headers": {
              "Authorization": "Bearer $REVA_CONNECTOR_TOKEN",
              "Content-Type": "application/json"
            },
            "allowedEnvVars": ["REVA_CONNECTOR_TOKEN"]
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "https://reva-plugin.onrender.com/api/pdp/evaluate",
            "timeout": 30,
            "headers": {
              "Authorization": "Bearer $REVA_CONNECTOR_TOKEN",
              "Content-Type": "application/json"
            },
            "allowedEnvVars": ["REVA_CONNECTOR_TOKEN"]
          }
        ]
      }
    ]
  }
}
